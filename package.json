{
	"name": "mealpreping",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.6.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"check": "pnpm paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "pnpm paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "vitest run"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.18.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
